# Single key setup: agents and judges all route through OpenRouter.
OPENROUTER_API_KEY=sk-or-v1-...

# Route judge/generation calls through an OpenAI-compatible gateway.
OPENCODE_ZEN_BASE_URL=https://openrouter.ai/api/v1
OPENCODE_ZEN_ENDPOINT=chat

# Judge panel, summary/prompt-generation models (gateway model IDs).
OPENCODE_BENCH_JUDGES=anthropic/claude-sonnet-5,openai/gpt-5.4,google/gemini-3.1-pro-preview
OPENCODE_BENCH_SUMMARY_MODEL=anthropic/claude-sonnet-5
OPENCODE_BENCH_GENERATE_MODEL=anthropic/claude-sonnet-5

# Agent models offered in the UI launcher (opencode provider/model IDs).
OPENCODE_BENCH_EXTRA_MODELS=openrouter/openai/gpt-5.4,openrouter/anthropic/claude-sonnet-5,openrouter/anthropic/claude-opus-4.8,openrouter/openai/gpt-5.3-codex,openrouter/z-ai/glm-5.2,openrouter/moonshotai/kimi-k2.7-code

# Time budgets (minutes). Episode covers agent + judging; agent is the
# coding phase only — on cutoff the work tree is scored as-is.
OPENCODE_BENCH_EPISODE_TIMEOUT_MINS=40
OPENCODE_BENCH_AGENT_TIMEOUT_MINS=15

# Web UI bind address (Docker sets HOST=0.0.0.0).
#HOST=127.0.0.1
#PORT=4700
